DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nightout
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Leave blank to disable a provider; at least one of Google or Foursquare is required for search
GOOGLE_PLACES_API_KEY=
FOURSQUARE_API_KEY=

# OSM/Nominatim is opt-in only — strict rate limits (1 req/s) and usage policy make it unsuitable as a default
ENABLE_OSM=false
